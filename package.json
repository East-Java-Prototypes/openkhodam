{
  "name": "openkhodam",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "private": true,
  "author": "example.com",
  "license": "MIT",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "typecheck": "pnpm --filter @openkhodam/ui typecheck && pnpm --filter @openkhodam/desktop typecheck",
    "typecheck:desktop": "pnpm --filter @openkhodam/desktop typecheck",
    "typecheck:ui": "pnpm --filter @openkhodam/ui typecheck",
    "start": "pnpm --filter @openkhodam/desktop start",
    "dev": "pnpm --filter @openkhodam/desktop dev",
    "build": "pnpm --filter @openkhodam/desktop build",
    "build:unpack": "pnpm --filter @openkhodam/desktop build:unpack",
    "build:win": "pnpm --filter @openkhodam/desktop build:win",
    "build:mac": "pnpm --filter @openkhodam/desktop build:mac",
    "build:linux": "pnpm --filter @openkhodam/desktop build:linux",
    "test:e2e": "pnpm --filter @openkhodam/e2e test",
    "test:unit": "pnpm --filter @openkhodam/desktop test:unit"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "msw",
      "opencode-ai"
    ]
  }
}
