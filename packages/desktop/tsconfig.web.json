{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "../ui/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/renderer/src/*"
      ],
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@openkhodam/ui": [
        "../ui/src/index.ts"
      ],
      "@openkhodam/ui/types": [
        "../ui/src/types.ts"
      ],
      "@openkhodam/ui/*": [
        "../ui/src/*"
      ]
    }
  }
}
